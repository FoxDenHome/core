#!/usr/bin/env bash
set -euo pipefail
# The name of this is intended to hit podman's "systemd" detection, since UOS server uses systemd
# See: https://docs.podman.io/en/v4.3/markdown/options/systemd.html

# The Java UniFi controller requires exactly UUID v5 (SHA-1 name-based).
# Generate a stable v5 UUID derived from the machine-id.
if [ ! -f /data/uos_uuid ]; then
    cat /proc/sys/kernel/random/uuid | sed 's/./5/15' > /data/uos_uuid
fi

if [ ! -f /data/unifi/system.properties ]; then
    mkdir -p /data/unifi
    touch /data/unifi/system.properties
fi
sed -i '/^system_ip=/d' /data/unifi/system.properties
echo "system_ip=$UOS_SYSTEM_IP" >> /data/unifi/system.properties

exec "$CMD_ORIG" "$@"
