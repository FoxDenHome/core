#!/usr/bin/env bash
set -euo pipefail
# The name of this is intended to hit podman's "systemd" detection, since UOS server uses systemd
# See: https://docs.podman.io/en/v4.3/markdown/options/systemd.html

# The Java UniFi controller requires exactly UUID v5 (SHA-1 name-based).
# Generate a random UUID v5 if it doesn't exist to make it happy.
if [ ! -f /data/uos_uuid ]; then
    cat /proc/sys/kernel/random/uuid | sed 's/./5/15' > /data/uos_uuid
fi

if [ ! -f /var/lib/unifi/system.properties ]; then
    touch /var/lib/unifi/system.properties
fi
sed -i '/^system_ip=/d' /var/lib/unifi/system.properties
echo "system_ip=$(ip -o -4 addr show dev eth0 | grep -oP '(?<=inet\s)\d+(\.\d+){3}')" >> /var/lib/unifi/system.properties

exec "$CMD_ORIG" "$@"
